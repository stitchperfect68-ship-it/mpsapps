# ─────────────────────────────────────────────────────────────────────────────
# MY PERFECT STITCH — Operations Suite
# Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────

APP_NAME="My Perfect Stitch"
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key:generate
APP_DEBUG=false
APP_TIMEZONE=Africa/Lusaka
APP_URL=https://ops.myperfectstitch.com
APP_LOCALE=en
APP_CURRENCY=ZMW
APP_COUNTRY=Zambia

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE (Shared MySQL — all 12 modules use this single database)
# ─────────────────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mps_operations
DB_USERNAME=mps_user
DB_PASSWORD=YOUR_SECURE_PASSWORD_HERE
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# ─────────────────────────────────────────────────────────────────────────────
# CACHE & SESSIONS (Redis for performance)
# ─────────────────────────────────────────────────────────────────────────────
CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=480
QUEUE_CONNECTION=redis

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL
# ─────────────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=info@myperfectstitch.co.zm
MAIL_PASSWORD=YOUR_EMAIL_PASSWORD
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=info@myperfectstitch.co.zm
MAIL_FROM_NAME="My Perfect Stitch"

# ─────────────────────────────────────────────────────────────────────────────
# FILE STORAGE
# ─────────────────────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=af-south-1
AWS_BUCKET=

# ─────────────────────────────────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────────────────────────────────
LOG_CHANNEL=daily
LOG_LEVEL=error
LOG_DEPRECATIONS_CHANNEL=null

# ─────────────────────────────────────────────────────────────────────────────
# BUSINESS SETTINGS
# ─────────────────────────────────────────────────────────────────────────────
MPS_VAT_RATE=16
MPS_NAPSA_RATE=5
MPS_NHIMA_RATE=1
MPS_COMPANY_ADDRESS="25 Parliament Road, Olympia, Lusaka, Zambia"
MPS_COMPANY_PHONE="+260 968 531 630"
MPS_COMPANY_EMAIL="info@myperfectstitch.co.zm"
MPS_TPIN=YOUR_ZRA_TPIN
MPS_INVOICE_PREFIX=MPS-INV
MPS_ORDER_PREFIX=MPS-ORD
MPS_PROJECT_PREFIX=MPS-PRJ

# ─────────────────────────────────────────────────────────────────────────────
# INTEGRATIONS
# ─────────────────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
WHATSAPP_API_URL=https://api.whatsapp.com
WHATSAPP_NUMBER=260968531630
